generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id          Int       @id @default(autoincrement())
  title       String
  category    String
  genre       String
  director    String
  year        Int
  imageUrl    String
  rating      Float
  description String
  releaseDate DateTime  @db.Timestamptz(6)
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt

  @@map("movies")
}
